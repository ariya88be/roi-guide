# ROI Guide — environment variable template.
# Copy to .env.local (gitignored) and fill in real values. NEVER commit secrets.
#
# Rule (brief §9): only the two CLERK PUBLISHABLE / public values may be exposed
# to the browser. Every other value here is SERVER-SIDE ONLY and must never be
# prefixed with NEXT_PUBLIC_. Provider and DB keys never reach the client.

# ---- Data providers (SERVER-SIDE ONLY) ----
RENTCAST_API_KEY=your_rentcast_api_key_here
ATTOM_API_KEY=your_attom_api_key_here
# Apify is a fallback scraper only; leave blank until/unless needed.
APIFY_API_TOKEN=

# ---- Database (SERVER-SIDE ONLY): PostgreSQL + PostGIS on Railway ----
# DATABASE_URL is the SUPERUSER connection — used ONLY for migrations
# (CREATE EXTENSION needs superuser).
DATABASE_URL=postgresql://postgres:password@host:5432/railway
# APP_DATABASE_URL is the non-superuser `roi_app` role used by the RUNTIME, so
# Row-Level Security is enforced (superusers bypass RLS). Create it with
# scripts/setup-app-role.mjs.
APP_DATABASE_URL=postgresql://roi_app:password@host:5432/railway

# ---- Redis (SERVER-SIDE ONLY): cache + rate limiting ----
REDIS_URL=redis://user:password@host:6379

# ---- Auth: Clerk ----
# Publishable key is intentionally public (safe to expose):
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Secret key is SERVER-SIDE ONLY — never NEXT_PUBLIC:
CLERK_SECRET_KEY=sk_test_xxx

# ---- Error tracking: Sentry ----
# DSN may be public by design; keep auth token server-side only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---- App config ----
# Comma-separated allowed origins for CORS in production (no wildcard in prod).
ALLOWED_ORIGINS=http://localhost:3000
